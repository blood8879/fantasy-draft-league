# AdMob 광고 단위 ID — 실제 배포 시 .env 파일로 복사해 채운다.
# 비워두면 구글 공식 테스트 광고 ID가 사용된다(개발 중에는 반드시 테스트 ID 사용).
# 값은 AdMob 콘솔 > 앱 > 광고 단위에서 발급받는다.

# 보상형 광고 (재경기 / 지명 되돌리기 / 스카우트 리포트)
VITE_ADMOB_REWARDED_ANDROID=
VITE_ADMOB_REWARDED_IOS=

# 전면 광고 (라운드 전환)
VITE_ADMOB_INTERSTITIAL_ANDROID=
VITE_ADMOB_INTERSTITIAL_IOS=

# 웹 H5 Games Ads 게시자 ID (예: ca-pub-1234567890123456)
# 비워두면 웹 광고(리롤·재경기 등)는 mock으로 폴백된다. AdSense H5 Games Ads 승인 후 입력.
VITE_ADSENSE_CLIENT=

# GameMonetize 게임 ID. 설정되면 웹 광고를 GameMonetize SDK로 처리한다(AdSense보다 우선).
# 게임 등록 후 발급되는 ID 입력. 비워두면 mock으로 폴백.
VITE_GAMEMONETIZE_ID=
